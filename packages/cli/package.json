{
  "name": "maintainer-bench",
  "version": "0.1.3",
  "description": "Repo-local regression tests for AI-assisted maintainer decisions.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/quasar529/maintainer-bench.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/quasar529/maintainer-bench/issues"
  },
  "homepage": "https://github.com/quasar529/maintainer-bench#readme",
  "bin": {
    "maintainer-bench": "./dist/index.cjs"
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/index.cjs",
    "dist/index.d.ts"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "default": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && pnpm run bundle",
    "bundle": "esbuild src/index.ts --bundle --platform=node --format=cjs --target=node20 --outfile=dist/index.cjs"
  },
  "dependencies": {}
}
