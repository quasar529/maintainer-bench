{
  "name": "maintainer-bench-repo",
  "version": "0.1.3",
  "private": true,
  "description": "Repo-local regression tests for AI-assisted maintainer decisions.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.23.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/quasar529/maintainer-bench.git"
  },
  "bugs": {
    "url": "https://github.com/quasar529/maintainer-bench/issues"
  },
  "homepage": "https://github.com/quasar529/maintainer-bench#readme",
  "scripts": {
    "build": "tsc -b && pnpm --filter maintainer-bench bundle",
    "test": "vitest run",
    "mb": "node packages/cli/dist/index.cjs",
    "dev:cli": "tsx packages/cli/src/index.ts",
    "verify": "pnpm build && pnpm test && pnpm mb run && pnpm mb grade && pnpm mb report --fail-on-failures"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "commander": "^14.0.3",
    "esbuild": "^0.28.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  }
}
